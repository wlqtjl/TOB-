# SkillQuest Environment Configuration
# Copy this file to .env and fill in values

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://skillquest:skillquest_dev@localhost:5432/skillquest

# ─── Redis (排行榜 + 缓存 + WebSocket pub/sub) ──────
REDIS_URL=redis://localhost:6379

# ─── API Server ───────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ─── Web App ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── AI Engine (Python FastAPI) ───────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
AI_ENGINE_URL=http://localhost:8000

# ─── WeChat Work (企业微信) ───────────────────────────
# Get these from: https://work.weixin.qq.com/wework_admin/frame#apps
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_SECRET=
WECHAT_WORK_REDIRECT_URI=http://localhost:3001/api/enterprise/wechat/callback
WECHAT_WORK_WEBHOOK_URL=

# ─── Feishu (飞书) ───────────────────────────────────
# Get these from: https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3001/api/enterprise/feishu/callback
FEISHU_WEBHOOK_URL=
